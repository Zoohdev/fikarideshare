{
  "expo": {
    "name": "Fika",
    "slug": "Fika",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Fika's-Logo.jpeg",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.render.rngopoolar",
      "buildNumber": "1.0.0",
      "supportsTablet": false
    },
    "android": {
      "package": "com.render.rngopoolar",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/FIKA_ppLogo.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBGv73TlYO0vjEQlPRjEfJiC5qhzwtgTB0"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/FIKA_ppLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#264D66"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your vehicle profile."
        }
      ]
    ],
    
    "experiments": {
      "typedRoutes": true
    }
  }
}
