# --- Windows-only GeoDjango overrides ---
# Leave unset to auto-detect a standard OSGeo4W install (C:\OSGeo4W or the
# per-user AppData install). Only set these if auto-detect doesn't find
# your install, or your share/ data lives somewhere non-standard.
# GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal313.dll
# GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll
# OSGEO4W_ROOT=C:\OSGeo4W
# PROJ_LIB=C:\OSGeo4W\share\proj
# GDAL_DATA=C:\OSGeo4W\share\gdal
